# ─────────────────────────────────────────────────────────────────────────────
# LLM Inference Stack — Environment Variables
# Copy to .env and fill in all values before first run.
# Generate secrets with: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (shared by Langfuse and LiteLLM) ───────────────────────────
POSTGRES_USER=llmadmin
POSTGRES_PASSWORD=CHANGE_ME_strong_postgres_password

# ── ClickHouse ────────────────────────────────────────────────────────────
CLICKHOUSE_DB=langfuse
CLICKHOUSE_USER=langfuse
CLICKHOUSE_PASSWORD=CHANGE_ME_strong_clickhouse_password

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# ── MinIO (S3-compatible blob store for Langfuse) ─────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password
LANGFUSE_S3_BUCKET_NAME=langfuse-events

# ── Langfuse v3 Secrets (generate each with: openssl rand -hex 32) ────────
LANGFUSE_SALT=CHANGE_ME_run_openssl_rand_hex_32
LANGFUSE_ENCRYPTION_KEY=CHANGE_ME_run_openssl_rand_hex_32
LANGFUSE_NEXTAUTH_SECRET=CHANGE_ME_run_openssl_rand_hex_32

# ── Langfuse Bootstrap (auto-creates org/project/admin on first start) ────
LANGFUSE_INIT_ORG_ID=bank-llm-org
LANGFUSE_INIT_ORG_NAME=Bank LLM Platform
LANGFUSE_INIT_PROJECT_ID=bank-llm-project
LANGFUSE_INIT_PROJECT_NAME=Bank LLM Production
LANGFUSE_PUBLIC_KEY=lf-pk-CHANGE_ME
LANGFUSE_SECRET_KEY=lf-sk-CHANGE_ME
LANGFUSE_ADMIN_EMAIL=admin@bank.internal
LANGFUSE_ADMIN_PASSWORD=CHANGE_ME_admin_password
LANGFUSE_ADMIN_NAME=LLM Admin

# ── LiteLLM ──────────────────────────────────────────────────────────────
# Master key for /v1 API — all clients must send: Authorization: Bearer <this>
LITELLM_MASTER_KEY=sk-CHANGE_ME_run_openssl_rand_hex_32
# UI dashboard credentials (http://<server>:4000/ui)
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=CHANGE_ME_litellm_ui_password

# ── Grafana ───────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_password
